//@version=5
indicator("functions/user_defined")
// Test user-defined functions

// Simple function
add(a, b) => a + b
result1 = add(5, 3)
log.info(str.tostring(result1))

// Function with multiple operations
double(x) => x * 2
result2 = double(7)
log.info(str.tostring(result2))

// Function calling another function
quadruple(x) => double(double(x))
result3 = quadruple(5)
log.info(str.tostring(result3))

// Function with conditional
sign(x) => x > 0 ? 1 : x < 0 ? -1 : 0
result4 = sign(10)
result5 = sign(-5)
result6 = sign(0)
log.info(str.tostring(result4))
log.info(str.tostring(result5))
log.info(str.tostring(result6))

// Expected output:
// 8
// 14
// 20
// 1
// -1
// 0
