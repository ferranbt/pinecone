// table.* create / mutate / delete. Tables have no getters in Pine, so this
// asserts the ids from table.new and that the cell / style / delete calls run
// without error (cell contents can't be read back from a script).
t = table.new(position.top_right, 2, 2, bgcolor=color.gray)
table.cell(t, 0, 0, "A", text_color=color.white)
table.cell(t, 1, 1, "B")
table.cell_set_text(t, 0, 0, "AA")
table.cell_set_bgcolor(t, 1, 1, color.red)
table.set_bgcolor(t, color.black)
log.info(str.tostring(t))

t2 = table.new(position.bottom_left, 1, 1)
log.info(str.tostring(t2))
table.clear(t2)
table.delete(t2)

// Expected output:
// 0
// 1
