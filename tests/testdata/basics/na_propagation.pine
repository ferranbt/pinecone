// Pine v6 na propagation semantics

// Arithmetic with na propagates na
x = na
y = x + 1
log.info(str.tostring(y))

// Comparison with na yields na
b = x > 0
log.info(str.tostring(b))

// Three-valued logic: false absorbs na
c = false and x > 0
log.info(str.tostring(c))

// Three-valued logic: true absorbs na
d = true or x > 0
log.info(str.tostring(d))

// na doubles as a function: na(x) tests for na
e = na(x)
log.info(str.tostring(e))

// An na condition takes the false/else branch; if-expression
// without an else yields na
f = if x > 0
    1
log.info(str.tostring(f))

// Expected output:
// NaN
// NaN
// false
// true
// true
// NaN
