// An na left operand cannot decide `and` alone, so the right operand IS
// evaluated (its value is needed to choose between na and false). Reaching the
// out-of-bounds array access errors, proving the operand was not skipped.
arr = array.new_float(0, 0.0)
cond = na
x = cond and (array.get(arr, 0) > 0)

