//@version=5
indicator("basics/lazy_na_left_evaluates_right_or")
// An na left operand cannot decide `or` alone, so the right operand IS
// evaluated (its value is needed to choose between na and true). Reaching the
// out-of-bounds array access errors, proving the operand was not skipped.
arr = array.new_float(0, 0.0)
cond = na
x = cond or (array.get(arr, 0) > 0)

// Expected error: Index out of bounds
