// Test arithmetic operators

// Addition
add1 = 10 + 5
add2 = -3 + 7
add3 = 2.5 + 3.5

// Subtraction
sub1 = 10 - 5
sub2 = 3 - 7
sub3 = 5.5 - 2.5

// Multiplication
mul1 = 5 * 4
mul2 = -3 * 2
mul3 = 2.5 * 4

// Division
div1 = 20 / 4
div2 = 15 / 2
div3 = -10 / 2

// Modulo
mod1 = 10 % 3
mod2 = 15 % 4

log.info(str.tostring(add1))
log.info(str.tostring(add2))
log.info(str.tostring(add3))
log.info(str.tostring(sub1))
log.info(str.tostring(sub2))
log.info(str.tostring(sub3))
log.info(str.tostring(mul1))
log.info(str.tostring(mul2))
log.info(str.tostring(mul3))
log.info(str.tostring(div1))
log.info(str.tostring(div2))
log.info(str.tostring(div3))
log.info(str.tostring(mod1))
log.info(str.tostring(mod2))

// Expected output:
// 15
// 4
// 6
// 5
// -4
// 3
// 20
// -6
// 10
// 5
// 7.5
// -5
// 1
// 3
