//@version=5
indicator("math/sum")
// Test math.sum with variadic arguments
result1 = math.sum(5, 3)
result2 = math.sum(10, 5, 3, 8)
result3 = math.sum(1, 2, 3, 4, 5)

log.info(str.tostring(result1))
log.info(str.tostring(result2))
log.info(str.tostring(result3))

// Expected output:
// 8
// 26
// 15
