//@version=5
indicator("math/logarithms")
// Test logarithmic and exponential functions

// Natural logarithm
log1 = math.log(math.exp(1))
log.info(str.tostring(log1))

// Base-10 logarithm
log10_1 = math.log10(100)
log10_2 = math.log10(1000)
log.info(str.tostring(log10_1))
log.info(str.tostring(log10_2))

// Exponential
exp1 = math.exp(0)
exp2 = math.exp(1)
log.info(str.tostring(exp1))
log.info(str.tostring(exp2))

// Expected output:
// 1
// 2
// 3
// 1
// 2.718281828459045
