//@version=5
indicator("math/basic")
// Test basic math functions

// abs
abs1 = math.abs(-5.5)
abs2 = math.abs(3.2)

// ceil
ceil1 = math.ceil(4.2)
ceil2 = math.ceil(-4.8)

// floor
floor1 = math.floor(4.8)
floor2 = math.floor(-4.2)

// round
round1 = math.round(4.5)
round2 = math.round(4.4)

log.info(str.tostring(abs1))
log.info(str.tostring(abs2))
log.info(str.tostring(ceil1))
log.info(str.tostring(ceil2))
log.info(str.tostring(floor1))
log.info(str.tostring(floor2))
log.info(str.tostring(round1))
log.info(str.tostring(round2))

// Expected output:
// 5.5
// 3.2
// 5
// -4
// 4
// -5
// 5
// 4
