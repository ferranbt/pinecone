// Test line basic operations: create, read back endpoints, interpolate price.
l = line.new(0, 10.0, 10, 30.0)
log.info(str.tostring(line.get_x1(l)))
log.info(str.tostring(line.get_y1(l)))
log.info(str.tostring(line.get_x2(l)))
log.info(str.tostring(line.get_y2(l)))
// price at x=5: 10 + (30-10)*(5-0)/(10-0) = 20
log.info(str.tostring(line.get_price(l, 5)))

// Expected output:
// 0
// 10
// 10
// 30
// 20
