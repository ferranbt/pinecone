//@version=5
indicator("constants/const_function_param_valid")
// Test that const function parameters work with const arguments

add(const int x, const int y) => x + y

const int a = 10
const int b = 20

// Literals are const
result1 = add(5, 10)
log.info(str.tostring(result1))

// Const variables are const
result2 = add(a, b)
log.info(str.tostring(result2))

// Expected output:
// 15
// 30
