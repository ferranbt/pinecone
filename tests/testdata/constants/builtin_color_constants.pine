//@version=5
indicator("constants/builtin_color_constants")
// Test builtin color constants

red_val = color.red
blue_val = color.blue
green_val = color.green

// Test color component extraction
r = color.r(red_val)
g = color.g(green_val)
b = color.b(blue_val)

log.info(str.tostring(r))
log.info(str.tostring(g))
log.info(str.tostring(b))

// Expected output:
// 255
// 128
// 255
