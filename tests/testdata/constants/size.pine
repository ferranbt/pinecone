// size.* constants resolve to their string tag.
log.info(str.tostring(size.auto))
log.info(str.tostring(size.tiny))
log.info(str.tostring(size.small))
log.info(str.tostring(size.normal))
log.info(str.tostring(size.large))
log.info(str.tostring(size.huge))

// Expected output:
// auto
// tiny
// small
// normal
// large
// huge
