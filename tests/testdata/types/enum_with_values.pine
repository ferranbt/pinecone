// Test enums with explicit string values
enum Signal
    buy = "Buy signal"
    sell = "Sell signal"
    neutral

x = Signal.buy
y = Signal.sell
z = Signal.neutral

log.info(str.tostring(x))
log.info(str.tostring(y))
log.info(str.tostring(z))

// Expected output:
// Signal::buy
// Signal::sell
// Signal::neutral
