// input.* returns its default value; the settings-UI arguments
// (title / minval / maxval / step / options / group) are accepted and ignored
// in a headless run. `input.integer` is the v4 spelling of `input.int`.
len = input.int(14, 'Length', minval = 1)
cols = input.int(title = 'Columns', minval = 1, defval = 15)
coef = input.float(2, minval = 0, maxval = 100, step = 0.1, title = 'Coef')
show = input.bool(title = 'Show', defval = true, group = 'cfg')
kind = input.string('Daily', title = 'Type', options = ['Daily', 'Weekly'])
sess = input.session('0900-1530', title = 'Session')
legacy = input.integer(7, title = 'Legacy')

log.info(len)
log.info(cols)
log.info(coef)
log.info(show)
log.info(kind)
log.info(sess)
log.info(legacy)

// Expected output:
// 14
// 15
// 2
// true
// Daily
// 0900-1530
// 7
