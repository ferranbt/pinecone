//@version=5
// v5 input: the type IS the function name (`input.int(...)`). Returns the
// default; minval/options only shape the settings UI.
length = input.int(14, "Length", minval=1)
factor = input.float(2.5, "Factor")
useClose = input.bool(true, "Use Close")
maType = input.string("EMA", "MA Type", options=["EMA", "SMA"])

log.info(length)
log.info(factor)
log.info(useClose)
log.info(maType)

// Expected output:
// 14
// 2.5
// true
// EMA
