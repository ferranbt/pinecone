// The harness runs daily bars, so timeframe reflects that.
//@version=6
log.info(timeframe.period)
log.info(str.tostring(timeframe.multiplier))
log.info(str.tostring(timeframe.isdaily))
log.info(str.tostring(timeframe.isintraday))
log.info(str.tostring(timeframe.isdwm))
log.info(str.tostring(timeframe.in_seconds('1D')))
log.info(timeframe.from_seconds(3600))

// Expected output:
// 1D
// 1
// true
// false
// true
// 86400
// 60
