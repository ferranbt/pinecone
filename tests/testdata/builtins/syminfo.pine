// Test the syminfo namespace exposes the host-supplied symbol information.
// The integration harness compiles every script with a fixed SymInfo (see
// test_syminfo in integration.rs); these are its values.
log.info(syminfo.ticker)
log.info(syminfo.tickerid)
log.info(syminfo.description)
log.info(syminfo.prefix)
log.info(syminfo.currency)
log.info(syminfo.basecurrency)
log.info(syminfo.mintick)
log.info(syminfo.pointvalue)
log.info(syminfo.timezone)
log.info(syminfo.session)

// Expected output:
// AAPL
// NASDAQ:AAPL
// Apple Inc.
// NASDAQ
// USD
// USD
// 0.01
// 1
// America/New_York
// 0930-1600
