//@version=5
indicator("builtins/syminfo")
// Test the syminfo namespace exposes the host-supplied symbol information.
// The integration harness compiles every script with a fixed SymInfo (see
// test_syminfo in integration.rs); these are its values.
log.info(str.tostring(syminfo.ticker))
log.info(str.tostring(syminfo.tickerid))
log.info(str.tostring(syminfo.description))
log.info(str.tostring(syminfo.prefix))
log.info(str.tostring(syminfo.currency))
log.info(str.tostring(syminfo.basecurrency))
log.info(str.tostring(syminfo.mintick))
log.info(str.tostring(syminfo.pointvalue))
log.info(str.tostring(syminfo.timezone))
log.info(str.tostring(syminfo.session))

// Expected output:
// AAPL
// NASDAQ:AAPL
// Apple Inc.
// NASDAQ
// USD
// USD
// 0.01
// 1
// America/New_York
// 0930-1600
