//@version=5
indicator("variables/compound_assignment")
// Test compound assignment operators

// Addition assignment
var x = 10
x += 5
log.info(str.tostring(x))

// Subtraction assignment
var y = 20
y -= 7
log.info(str.tostring(y))

// Multiplication assignment
var z = 5
z *= 3
log.info(str.tostring(z))

// Division assignment
var w = 30
w /= 6
log.info(str.tostring(w))

// Expected output:
// 15
// 13
// 15
// 5
